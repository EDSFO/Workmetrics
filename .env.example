# Database
DATABASE_URL="postgresql://workmetrics:workmetrics@localhost:5432/workmetrics?schema=public"

# PostgreSQL (for docker-compose)
POSTGRES_USER=workmetrics
POSTGRES_PASSWORD=workmetrics
POSTGRES_DB=workmetrics
POSTGRES_PORT=5432

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# App
NODE_ENV=development
PORT=3001

# Frontend URL (for CORS)
CORS_ORIGIN=http://localhost:3000

# Optional: Redis
# REDIS_PORT=6379
