# Database
DATABASE_URL="postgresql://workmetrics:workmetrics@localhost:5432/workmetrics?schema=public"

# PostgreSQL (for docker-compose)
POSTGRES_USER=workmetrics
POSTGRES_PASSWORD=workmetrics
POSTGRES_DB=workmetrics
POSTGRES_PORT=5432

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# App
NODE_ENV=development
PORT=3001

# Frontend URL (for CORS)
CORS_ORIGIN=http://localhost:3000

# Frontend API URL (for Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001/v1

# Docker production URLs (use these in production)
# DATABASE_URL="postgresql://workmetrics:workmetrics@postgres:5432/workmetrics"
# CORS_ORIGIN=http://frontend:3000
# NEXT_PUBLIC_API_URL=http://backend:3001/v1

# Optional: Redis
# REDIS_PORT=6379

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx
FRONTEND_URL=http://localhost:3000
