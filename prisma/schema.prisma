generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         String    @default("USER") // ADMIN, MANAGER, USER
  teamId       String?   @map("team_id")
  hourlyRate   Decimal?  @map("hourly_rate") @db.Decimal(10, 2)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  team          Team?        @relation(fields: [teamId], references: [id])
  timeEntries   TimeEntry[]
  teamOwner     Team?        @relation("TeamOwner")

  @@map("User")
}

model Team {
  id        String   @id @default(uuid())
  name      String
  ownerId   String   @unique @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner     User     @relation("TeamOwner", fields: [ownerId], references: [id])
  users     User[]
  projects  Project[]
  invitations TeamInvitation[]

  @@map("Team")
}

model Project {
  id           String    @id @default(uuid())
  name         String
  description  String?   @db.Text
  teamId       String    @map("team_id")
  budgetHours  Decimal?  @map("budget_hours") @db.Decimal(10, 2)
  budgetAmount Decimal?  @map("budget_amount") @db.Decimal(12, 2)
  archived     Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  team        Team        @relation(fields: [teamId], references: [id])
  tasks       Task[]
  timeEntries TimeEntry[]

  @@map("Project")
}

model Task {
  id             String    @id @default(uuid())
  projectId      String    @map("project_id")
  name           String
  estimatedHours Decimal?  @map("estimated_hours") @db.Decimal(10, 2)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  project      Project      @relation(fields: [projectId], references: [id])
  timeEntries  TimeEntry[]

  @@map("Task")
}

model TimeEntry {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  projectId   String?   @map("project_id")
  taskId      String?   @map("task_id")
  startTime   DateTime  @map("start_time")
  endTime     DateTime? @map("end_time")
  duration    Int?      // Duration in seconds
  description String?   @db.Text
  billable    Boolean   @default(true)
  type        String    @default("TIME") // TIME, CLOCK_IN, CLOCK_OUT, PAUSE, RESUME, AUTO
  status      String    @default("APPROVED") // PENDING, APPROVED, REJECTED
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
  task    Task?    @relation(fields: [taskId], references: [id])

  @@index([userId])
  @@index([projectId])
  @@index([startTime])
  @@index([endTime])
  @@index([userId, startTime])
  @@map("TimeEntry")
}

model TeamInvitation {
  id        String   @id @default(uuid())
  teamId    String   @map("team_id")
  email     String
  token     String   @unique
  status    String   @default("PENDING") // PENDING, ACCEPTED, EXPIRED
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id])

  @@map("TeamInvitation")
}

model ScheduledEntry {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  projectId   String?  @map("project_id")
  taskId      String?  @map("task_id")
  description String?  @db.Text
  billable    Boolean  @default(true)

  // Schedule configuration
  startDate   DateTime @map("start_date")
  startTime   String   @map("start_time") // HH:mm format
  duration    Int      // Duration in seconds
  recurring   Boolean  @default(false)
  recurringPattern String? @map("recurring_pattern") // DAILY, WEEKLY, MONTHLY
  recurringDays String?  @map("recurring_days") // JSON array of days for WEEKLY: [1,2,3,4,5] (Mon-Fri)
  recurringEndDate DateTime? @map("recurring_end_date")

  // Status
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
  task    Task?    @relation(fields: [taskId], references: [id])

  @@index([userId])
  @@index([active])
  @@map("ScheduledEntry")
}

model TimeOff {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  type        String    // PTO, SICK, PARENTAL, BEREAVEMENT, OTHER
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  hours       Decimal   @map("hours") @db.Decimal(10, 2)
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  notes       String?   @db.Text
  approverId  String?   @map("approver_id")
  approvedAt  DateTime? @map("approved_at")
  rejectionReason String? @map("rejection_reason")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user     User   @relation(fields: [userId], references: [id])
  approver User?  @relation("ApprovedTimeOff", fields: [approverId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("TimeOff")
}

model TimeOffPolicy {
  id          String   @id @default(uuid())
  teamId      String   @map("team_id")
  name        String   // e.g., "Paid Time Off", "Sick Leave"
  type        String   // PTO, SICK, PARENTAL, etc.
  accrualRate Decimal  @map("accrual_rate") @db.Decimal(5, 2) // Hours per pay period
  maxBalance  Decimal? @map("max_balance") @db.Decimal(10, 2) // Max accrual cap
  isPaid      Boolean  @default(true)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  team Team @relation(fields: [teamId], references: [id])

  @@map("TimeOffPolicy")
}

model ApiKey {
  id          String   @id @default(uuid())
  name        String   // Friendly name for the integration
  key         String   @unique @map("api_key") // The actual API key (hashed)
  keyPrefix   String   @map("key_prefix") // First 8 chars for identification
  teamId      String   @map("team_id")
  permissions String[]  // Specific endpoints allowed
  expiresAt   DateTime? @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id])

  @@index([key])
  @@index([teamId])
  @@map("ApiKey")
}

model Webhook {
  id          String   @id @default(uuid())
  teamId      String   @map("team_id")
  url         String   @map("webhook_url")
  events      String[] // Event types to trigger
  secret      String   @map("webhook_secret") // For signature verification
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id])

  @@index([teamId])
  @@map("Webhook")
}

model WebhookDelivery {
  id          String   @id @default(uuid())
  webhookId   String   @map("webhook_id")
  event       String   @map("event_type")
  payload     String   @db.Text // JSON payload
  status      String   @default("PENDING") // PENDING, SENT, FAILED
  attempts    Int      @default(0)
  response    String?  @db.Text
  deliveredAt DateTime? @map("delivered_at")
  createdAt   DateTime @default(now()) @map("created_at")

  webhook Webhook @relation(fields: [webhookId], references: [id])

  @@index([webhookId])
  @@index([status])
  @@map("WebhookDelivery")
}

model Integration {
  id        String   @id @default(uuid())
  teamId    String   @map("team_id")
  type      String   // slack, jira, linear
  config    Json     // Type-specific configuration
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  lastUsedAt DateTime? @map("last_used_at")

  team  Team               @relation(fields: [teamId], references: [id])
  links IntegrationLink[]

  @@index([teamId])
  @@index([type])
  @@map("Integration")
}

model IntegrationLink {
  id             String   @id @default(uuid())
  integrationId  String   @map("integration_id")
  externalId     String   @map("external_id") // e.g., Jira issue key, Linear issue ID
  timeEntryId   String?  @map("time_entry_id")
  createdAt     DateTime @default(now()) @map("created_at")

  integration Integration @relation(fields: [integrationId], references: [id])

  @@index([integrationId])
  @@index([timeEntryId])
  @@map("IntegrationLink")
}
